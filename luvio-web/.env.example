# Frontend environment variables for the React app (Netlify/local frontend).
# Only variables prefixed with REACT_APP_ are available in client code.

# Deployment environment label (optional)
REACT_APP_ENV=development

# Backend base URL used by checkout API calls
# Local: http://localhost:3001
# Production: https://your-backend-domain
REACT_APP_API_URL=http://localhost:3001

# Stripe publishable key (safe for frontend)
# Test: pk_test_...
# Live: pk_live_...
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Do NOT add STRIPE_SECRET_KEY or REACT_APP_STRIPE_SECRET_KEY here.
# Keep Stripe secret keys on the backend only.
